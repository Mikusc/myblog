<%
  var showHomeHero = typeof homeView !== 'undefined' ? homeView : is_home();
  var navI18nKeys = {
    '首页': 'nav.home',
    '课程笔记': 'nav.courseNotes',
    '项目': 'nav.projects',
    '关于': 'nav.about',
    '联系': 'nav.contact',
    '归档': 'nav.archives',
    '工具': 'nav.tools'
  };
  var currentPath = (page.path || '').replace(/index\.html$/, '').replace(/^\/+/, '');
  var normalizeMenuPath = function(path){
    return String(path || '').replace(/^\/+/, '').replace(/index\.html$/, '').replace(/\/$/, '');
  };
  var isMenuActive = function(label, path){
    if (is_home() && label === '首页') return true;
    var target = normalizeMenuPath(path);
    if (!target) return false;
    if (currentPath.indexOf(target + '/') === 0 || currentPath === target) return true;
    if (label === '课程笔记' && currentPath.indexOf('2026/01/08/comp4133aads') === 0) return true;
    if (label === '项目' && currentPath.indexOf('scene-shift/') === 0) return true;
    if (label === '工具' && currentPath.indexOf('bus/') === 0) return true;
    return false;
  };
%>
<header id="header" class="<%= showHomeHero ? 'site-header-home' : 'site-header-compact' %>">
  <% if (showHomeHero) { %>
    <div id="banner"></div>
  <% } %>
  <div id="header-outer" class="outer">
    <div id="header-inner" class="inner">
      <a class="site-wordmark" href="<%- url_for() %>">
        <span class="site-mark">M</span>
        <span class="site-name-wrap">
          <span class="site-name" data-i18n="site.name"><%= config.title %></span>
          <span class="site-tagline" data-i18n="site.tagline">Course Notes · Projects · Tech Notes</span>
        </span>
      </a>
      <div class="site-nav-panel navbar-wrapper">
        <div class="site-mobile-actions">
          <a class="site-mobile-search nav-search-btn" title="<%= __('search') %>"><span class="fa fa-search"></span></a>
          <a id="main-nav-toggle" class="site-mobile-menu" title="Menu"><span class="fa fa-bars"></span></a>
        </div>
        <div id="site-topbar" class="up-wrapper">
          <div class="site-utility">
            <% if (theme.links) { %>
              <div class="site-social-links">
                <% var siteLinkLabels = {github: 'GitHub', bilibili: 'B站', xiaohongshu: '小红书'}; %>
                <% var siteLinkI18nKeys = {github: 'social.github', bilibili: 'social.bilibili', xiaohongshu: 'social.xiaohongshu'}; %>
                <% for (const i in theme.links) {%>
                  <a class="site-utility-link" href="<%- url_for(theme.links[i]) %>"<% if (siteLinkI18nKeys[i]) { %> data-i18n="<%= siteLinkI18nKeys[i] %>"<% } %><% if (/^https?:\/\//.test(theme.links[i])) { %> target="_blank" rel="noopener"<% } %>><%= siteLinkLabels[i] || (i.charAt(0).toUpperCase() + i.slice(1)) %></a>
                <% } %>
              </div>
            <% } %>
            <span class="split-line"></span>
            <button class="site-language-switch js-language-toggle" type="button" aria-label="Language switch">
              <span class="site-language-link" data-i18n="language.toggle">English</span>
              <span class="fa fa-globe" aria-hidden="true"></span>
            </button>
            <span class="split-line"></span>
            <button class="site-theme-switch js-theme-toggle" type="button" aria-label="Theme switch">
              <span class="site-theme-label" data-i18n="theme.toggle">主题</span>
              <span class="site-theme-glyph" aria-hidden="true"></span>
            </button>
            <span class="split-line"></span>
            <div class="site-dropdown">
              <button class="site-dropdown-toggle" type="button" aria-haspopup="true">
                <span data-i18n="site.dropdownCurrent">Mikusc 的小站</span> <span class="site-down-caret"></span>
              </button>
              <div class="site-dropdown-menu" role="menu">
                <a class="site-dropdown-link site-dropdown-current" href="<%- url_for('/') %>" role="menuitem">
                  <span data-i18n="site.dropdownCurrent">Mikusc 的小站</span>
                </a>
                <% var arcaeaSwitch = theme.site_switch && theme.site_switch.arcaea_tencent; %>
                <a class="site-dropdown-link" href="<%- url_for(arcaeaSwitch && arcaeaSwitch.url ? arcaeaSwitch.url : '#') %>" role="menuitem"<% if (arcaeaSwitch && /^https?:\/\//.test(arcaeaSwitch.url || '')) { %> target="_blank" rel="noopener"<% } %>>
                  <span data-i18n="site.arcaeaChannel"><%= arcaeaSwitch && arcaeaSwitch.label ? arcaeaSwitch.label : '韵律源点 Arcaea 腾讯频道' %></span>
                </a>
              </div>
            </div>
          </div>
          <div id="search-form-wrap">
            <%- search_form({button: '&#xF002;', text: __('search')}) %>
          </div>
        </div>
        <div id="site-nav-row" class="down-wrapper">
          <nav id="main-nav">
            <% for (var i in theme.menu){ %>
              <% var active = isMenuActive(i, theme.menu[i]); %>
              <a class="main-nav-link<%= active ? ' is-active' : '' %>" href="<%- url_for(theme.menu[i]) %>"<% if (active) { %> aria-current="page"<% } %><% if (navI18nKeys[i]) { %> data-i18n="<%= navI18nKeys[i] %>"<% } %>><%= i %></a>
            <% } %>
          </nav>
        </div>
      </div>
    </div>
    <% if (showHomeHero) { %>
      <div id="header-title" class="inner">
        <h1 id="logo-wrap">
          <a href="<%- url_for() %>" id="logo" data-i18n="site.name"><%= config.title %></a>
        </h1>
        <% if (theme.subtitle || config.subtitle){ %>
          <h2 id="subtitle-wrap">
            <a href="<%- url_for() %>" id="subtitle" data-i18n="site.heroSubtitle"><%= theme.subtitle || config.subtitle %></a>
          </h2>
        <% } %>
        <a class="site-hero-cta" href="<%- url_for('/about/') %>">
          <span class="site-hero-cta-text" data-i18n="hero.cta">了解更多</span>
          <span class="site-hero-cta-icon site-drawn-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M7 17L17 7M9 7h8v8"></path>
            </svg>
          </span>
        </a>
      </div>
    <% } %>
  </div>
</header>
