<%
  var mobileNavI18nKeys = {
    '首页': 'nav.home',
    '课程笔记': 'nav.courseNotes',
    '项目': 'nav.projects',
    '关于': 'nav.about',
    '联系': 'nav.contact',
    '归档': 'nav.archives',
    '工具': 'nav.tools'
  };
%>
<nav id="mobile-nav">
  <div class="mobile-utility">
    <% if (theme.links && theme.links.github) { %>
      <div class="mobile-social-links">
        <a class="mobile-utility-link" href="<%- url_for(theme.links.github) %>"<% if (/^https?:\/\//.test(theme.links.github)) { %> target="_blank" rel="noopener"<% } %>>GitHub</a>
      </div>
    <% } %>
    <span class="mobile-split-line"></span>
    <button class="mobile-language-switch js-language-toggle" type="button" aria-label="Language switch">
      <span data-i18n="language.toggle">English</span>
      <span class="fa fa-globe" aria-hidden="true"></span>
    </button>
    <span class="mobile-split-line"></span>
    <details class="mobile-site-switch">
      <summary>
        <span data-i18n="site.dropdownCurrent">Mikusc 的小站</span>
        <span class="mobile-down-caret" aria-hidden="true"></span>
      </summary>
      <div class="mobile-site-switch-menu">
        <a class="mobile-site-switch-link mobile-site-switch-current" href="<%- url_for('/') %>" data-i18n="site.dropdownCurrent">Mikusc 的小站</a>
        <% var arcaeaSwitch = theme.site_switch && theme.site_switch.arcaea_tencent; %>
        <a class="mobile-site-switch-link" href="<%- url_for(arcaeaSwitch && arcaeaSwitch.url ? arcaeaSwitch.url : '#') %>"<% if (arcaeaSwitch && /^https?:\/\//.test(arcaeaSwitch.url || '')) { %> target="_blank" rel="noopener"<% } %> data-i18n="site.arcaeaChannel"><%= arcaeaSwitch && arcaeaSwitch.label ? arcaeaSwitch.label : '韵律源点 Arcaea 腾讯频道' %></a>
      </div>
    </details>
  </div>
  <% for (var i in theme.menu){ %>
    <a href="<%- url_for(theme.menu[i]) %>" class="mobile-nav-link"<% if (mobileNavI18nKeys[i]) { %> data-i18n="<%= mobileNavI18nKeys[i] %>"<% } %>><%= i %></a>
  <% } %>
</nav>
