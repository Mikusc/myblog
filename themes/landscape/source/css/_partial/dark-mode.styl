html[data-theme="dark"]
  body
    background: var(--bg-1)
    color: var(--ink)

  #wrap
    background: var(--bg-1)

  #header,
  #header-inner,
  #mobile-nav,
  #search-form-wrap
    background: var(--surface-1)
    border-color: var(--border)
    color: var(--ink)

  #header-inner.is-scrolled
    border-bottom-color: var(--border)

  #site-topbar,
  .mobile-utility,
  .mobile-nav-link,
  .article-detail .article-footer,
  .content-section-head,
  .home-section-head,
  .archive-year-wrap
    border-color: var(--border)

  .site-wordmark,
  .site-utility-link,
  .site-language-switch,
  .site-language-link,
  .site-theme-switch,
  .site-dropdown-toggle,
  .main-nav-link,
  .nav-icon,
  .mobile-utility,
  .mobile-utility-link,
  .mobile-language-switch,
  .mobile-theme-switch,
  .mobile-site-switch summary,
  .mobile-nav-link,
  .site-mobile-search,
  #main-nav-toggle
    color: var(--ink)

  .site-tagline,
  #site-topbar,
  .search-result,
  .search-result-head,
  .search-empty,
  .content-card-desc,
  .content-note-panel p,
  .content-card-meta,
  .content-link-row span,
  .course-flow-item span,
  .course-flow-item em,
  .course-series-kicker,
  .article-toc summary em,
  .article-detail .article-meta,
  .article-detail .article-date,
  .article-detail .article-category,
  .article-detail .article-tag-list-link,
  .article-detail .article-nav-caption,
  .article-category,
  .caption,
  .home-section-kicker,
  .home-section-note,
  .home-overview-text,
  .home-stat-desc,
  .home-news-excerpt,
  .home-event-year,
  .home-event-type,
  .home-pathway-desc,
  .widget,
  .archive-article-date,
  .archive-article-category,
  .archive-article-category a,
  #page-nav,
  #page-nav a
    color: var(--muted)

  .home-news-media,
  .home-arrow-button,
  .content-hub-hero,
  .listing-hero,
  .content-tool-status,
  .link-btn-wrapper
    background: #10263b
    color: #fff

  .site-mark
    background: var(--ink)
    color: #10263b

  .split-line,
  .mobile-split-line
    background: var(--muted)
    opacity: 0.7

  .site-down-caret,
  .mobile-down-caret
    border-top-color: var(--ink)

  .main-nav-link:after
    background: var(--ink)

  #main-nav-toggle .fa,
  #main-nav-toggle .fa:before,
  #main-nav-toggle .fa:after
    background: var(--ink)

  .mobile-nav-on #main-nav-toggle .fa
    background: transparent

  .site-theme-glyph
    background: currentColor
    box-shadow: 0 0 0 3px rgba(238, 245, 251, 0.08)
    &:after
      background: var(--surface-1)
      border-color: var(--surface-1)
      transform: scale(1)

  .site-dropdown-menu,
  .mobile-site-switch-menu,
  .search-form,
  #local-search-result,
  .article-inner,
  .article-detail .article-inner,
  .article-share-box,
  .article-share-input,
  .home-overview-panel,
  .home-news-card,
  .home-event-card,
  .home-pathway-card,
  .content-stat-grid,
  .content-card,
  .content-link-list,
  .content-chip-row a,
  .content-feature-card,
  .content-tool-card,
  .content-note-panel,
  .course-flow,
  .course-series-nav,
  .article-toc,
  .article-detail .article-nav-link-wrap,
  .archive-article-inner,
  #page-nav,
  .widget
    background: var(--surface-1)
    border-color: var(--border)
    color: var(--ink)

  .search-form
    background: var(--surface-2)

  .search-form-input,
  .search-form-submit,
  .search-result-title,
  .search-keyword,
  .site-dropdown-link,
  .mobile-site-switch-link,
  .article-title,
  .article-entry,
  .article-entry p,
  .article-entry li,
  .article-entry a,
  .content-hub,
  .article-entry .content-hub a,
  .content-card-title,
  .content-section-title,
  .content-feature-title,
  .content-stat-number,
  .content-stat-label,
  .content-link-row strong,
  .content-chip-row a,
  .course-flow-item,
  .course-flow-item strong,
  .course-series-head strong,
  .course-series-directory,
  .course-series-link,
  .course-series-link strong,
  .article-toc summary,
  .article-toc a,
  .article-detail .article-category-link,
  .article-detail .article-entry,
  .article-detail .article-entry p,
  .article-detail .article-entry li,
  .article-detail .article-nav-link-wrap,
  .article-detail .article-nav-title,
  .article-detail .article-tag-list-link:hover,
  .home-section-title,
  .home-arrow-link,
  .home-overview-title,
  .home-stat-number,
  .home-stat-label,
  .home-column-title,
  .home-column-link,
  .home-inline-arrow,
  .home-news-card,
  .home-news-title,
  .home-event-card,
  .home-event-day,
  .home-event-title,
  .home-pathway-card,
  .home-pathway-title,
  .home-pathway-footer,
  .archive-year,
  .archive-article-title,
  .archive-article-title:hover,
  #page-nav .current,
  .widget-title,
  .widget a
    color: var(--ink)

  .search-form-input::placeholder
    color: rgba(238, 245, 251, 0.48)

  .site-dropdown-link:hover,
  .mobile-site-switch-link:hover,
  .search-result-list li:hover,
  .mobile-nav-link:hover,
  .mobile-nav-link.is-active,
  .content-card:hover,
  .content-link-row:hover,
  .content-chip-row a:hover,
  .course-flow-item:hover,
  .course-series-link:hover,
  .article-toc a:hover,
  .article-toc a.is-active,
  .article-detail .article-nav-link-wrap:hover,
  .home-news-card:hover,
  .home-event-card:hover,
  .home-pathway-card:hover,
  .article-detail .article-tag-list-link,
  .article-detail .article-entry blockquote,
  .article-detail .article-entry code
    background: var(--hover-bg)

  .content-card:hover,
  .content-chip-row a:hover,
  .content-action,
  .content-action-primary,
  .article-more-link a,
  .article-detail .article-nav-link-wrap:hover,
  .archive-article-inner:hover
    border-color: var(--ink)

  .content-card-meta span
    background: var(--surface-2)
    border-color: var(--border)
    color: var(--muted)

  .content-stat,
  .content-link-row,
  .course-flow-item,
  .course-series-head,
  .course-series-link,
  .article-toc li,
  .home-overview-copy,
  .home-stat,
  .home-event-datebox,
  .search-result-list li,
  .search-result-head,
  .article-entry .article-table-scroll,
  .article-entry th,
  .article-entry td
    border-color: var(--border)

  .content-action
    background: var(--surface-1)
    color: var(--ink)
    border-color: var(--ink)
    > span:not(.content-action-icon)
      color: var(--ink)
      -webkit-text-fill-color: var(--ink)
    &:hover
      background: var(--ink)
      color: #07111c
      > span:not(.content-action-icon)
        color: #07111c
        -webkit-text-fill-color: #07111c

  .content-action-primary,
  .article-more-link a
    background: var(--ink)
    color: #07111c
    border-color: var(--ink)
    > span:not(.content-action-icon)
      color: #07111c
      -webkit-text-fill-color: #07111c
    &:hover
      background: var(--surface-1)
      color: var(--ink)
      > span:not(.content-action-icon)
        color: var(--ink)
        -webkit-text-fill-color: var(--ink)

  .content-action-icon,
  .article-more-icon
    background: var(--surface-1)
    color: var(--ink)

  .content-action:not(.content-action-primary) .content-action-icon
    background: var(--ink)
    color: #07111c

  .content-action:not(.content-action-primary):hover .content-action-icon,
  .content-action-primary:hover .content-action-icon,
  .article-more-link a:hover .article-more-icon
    background: var(--ink)
    color: #07111c

  .article-more-link a:hover
    background: var(--surface-1)
    color: var(--ink)

  .content-card-social.content-card-social-github
    background: var(--surface-1)

  .content-card-social.content-card-social-repository
    background: #10263b
    border-color: #10263b

  .content-card-social.content-card-social-bilibili
    background: #fb7299
    border-color: #fb7299

  .content-card-social.content-card-social-rednote
    background: #ff2442
    border-color: #ff2442

  .article-entry .article-table-scroll,
  .article-entry table
    background: var(--surface-1)
    color: var(--ink)
    border-color: var(--border)

  .article-entry th
    background: var(--surface-2)
    color: var(--ink)

  .article-entry tbody tr:nth-child(even) td
    background: rgba(255, 255, 255, 0.03)

  .article-detail .article-entry pre,
  .article-detail .article-entry .highlight
    background: #06101c

  .article-share-links
    background: var(--surface-2)

  .article-share-input
    border-color: var(--border)

  .article-footer
    border-top-color: var(--border)
    a
      color: var(--muted)
      &:hover
        color: var(--ink)

  .article-nav-link-wrap
    color: var(--muted)
    text-shadow: none
    &:hover
      color: var(--ink)

  #article-nav:before
    background: var(--border)
    box-shadow: none

  .article-nav-caption
    color: var(--muted)

  .article-detail .article-entry h1,
  .article-detail .article-entry h2
    border-top-color: var(--border)

  #page-nav a:hover
    background: var(--ink)
    color: #07111c

  .footer-link-wrapper
    background: var(--surface-1)
    color: var(--ink)

  #footer .footer-link-wrapper
    color: var(--ink)

  .footer-link-wrapper .link-btn-wrapper
    background: var(--ink)
    color: #07111c
