@media mq-mobile-tablet
  #mobile-nav
    position: fixed
    top: 66px
    left: 0
    right: 0
    width: 100%
    height: unquote("calc(100vh - 66px)")
    padding: 26px 22px
    background: #fff
    border-top: 1px solid color-border
    border-right: 0
    opacity: 0
    visibility: hidden
    pointer-events: none
    transform: translateY(-12px)
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease
    z-index: 120
    overflow-y: auto

.mobile-nav-on
  overflow: visible

  #wrap
    left: 0

  #mobile-nav
    left: 0
    opacity: 1
    visibility: visible
    pointer-events: auto
    transform: translateY(0)

@media mq-mobile-tablet
  .mobile-utility
    display: flex
    align-items: center
    flex-wrap: wrap
    gap: 16px
    padding: 4px 0 24px
    border-bottom: 1px solid color-border
    color: color-default
    font: 700 16px font-sans
    line-height: 1.2

  .mobile-social-links
    display: inline-flex
    align-items: center
    flex-wrap: wrap
    gap: 16px

  .mobile-utility-link,
  .mobile-language-switch,
  .mobile-site-switch summary
    color: color-default
    text-decoration: none

  .mobile-language-switch
    border: 0
    background: transparent
    padding: 0
    cursor: pointer
    font: inherit
    display: inline-flex
    align-items: center
    gap: 8px

  .mobile-split-line
    display: inline-block
    width: 1px
    height: 16px
    background: #000
    opacity: 0.72

  .mobile-site-switch
    position: relative

  .mobile-site-switch summary
    display: inline-flex
    align-items: center
    gap: 9px
    list-style: none
    cursor: pointer
    &::-webkit-details-marker
      display: none

  .mobile-down-caret
    width: 0
    height: 0
    display: inline-block
    border-left: 4px solid transparent
    border-right: 4px solid transparent
    border-top: 5px solid color-default
    transform: translateY(1px) rotate(0deg)
    transform-origin: center
    transition: transform 0.18s ease

  .mobile-site-switch[open] .mobile-down-caret
    transform: translateY(1px) rotate(180deg)

  .mobile-site-switch-menu
    position: absolute
    top: 30px
    left: 50%
    width: 238px
    padding: 14px 0
    background: #fff
    transform: translateX(-50%)
    z-index: 2

  .mobile-site-switch-link
    display: block
    padding: 7px 20px
    color: color-default
    text-decoration: none
    font-size: 16px
    line-height: 1.7
    white-space: nowrap

  .mobile-site-switch-current
    color: #7d8994

  .mobile-nav-link
    display: block
    color: color-default
    text-decoration: none
    padding: 18px 0
    border-bottom: 1px solid color-border
    font: 700 20px font-sans
    line-height: 1.25
    &:hover
      color: color-link

// Force single-column layout on mobile/tablet
@media mq-mobile-tablet
  #main
    float: none
    width: 100%
    margin: 0

  #sidebar
    display: none

  // Fix layout overlapping issues and typography
  .article-title
    font-size: 1.6rem !important
    line-height: 1.3em !important
    margin-bottom: 0.5em
  
  .article-inner
    padding: 24px 16px !important
    // Ensure content card doesn't overlap meta info too aggressively
    margin-top: 20px !important 
  
  .article-meta
    margin-bottom: 10px
    padding-left: 10px
    display: block
    width: 100%
    
  .article-entry
    padding: 0 !important
    
  #header
    height: 430px
    border-bottom: 0

  #header-outer
    padding: 0 22px

  #header-inner
    height: 66px
    display: flex
    align-items: center
    justify-content: space-between
    column-gap: 16px
    padding: 0 20px
    z-index: 230

  .site-utility
    display: none

  .site-wordmark
    min-width: 0
    font-size: 19px
    max-width: calc(100% - 84px)

  .site-mark
    width: 38px
    height: 38px
    margin-right: 9px
    font-size: 21px

  .site-name-wrap
    gap: 0

  .site-name
    overflow: hidden
    text-overflow: ellipsis

  .site-tagline
    display: none

  .site-nav-panel
    display: flex
    align-items: center
    justify-content: flex-end
    flex: 0 0 auto

  .site-mobile-actions
    display: flex
    align-items: center
    gap: 14px

  .site-mobile-search,
  #main-nav-toggle
    width: 22px
    height: 22px
    display: inline-flex
    align-items: center
    justify-content: center
    color: color-default
    border: 0
    background: transparent
    text-decoration: none
    cursor: pointer
    padding: 0

  .site-mobile-search
    font-size: 17px

  #main-nav-toggle
    position: relative
    .fa
      position: relative
      display: block
      width: 17px
      height: 1.5px
      margin: 0
      background: color-default
      font-size: 0
      line-height: 0
      &:before,
      &:after
        content: ""
        position: absolute
        left: 0
        width: 17px
        height: 1.5px
        background: color-default
      &:before
        top: -6px
      &:after
        top: 6px

  .mobile-nav-on #main-nav-toggle
    .fa
      background: transparent
      &:before
        top: 0
        transform: rotate(45deg)
      &:after
        top: 0
        transform: rotate(-45deg)

  #site-topbar
    height: auto
    border-bottom: 0
    gap: 0

  #site-nav-row
    display: none

  #search-form-wrap
    position: fixed
    top: 66px
    left: 0
    right: 0
    width: 100%
    height: auto
    padding: 12px 22px
    background: #fff
    border-top: 1px solid color-border
    border-bottom: 1px solid color-border
    opacity: 1
    z-index: 125

  .search-form
    position: relative
    height: 46px
    background: #f6f6f6
    border: 0
    border-radius: 999px
    padding: 0 16px 0 42px
    display: flex
    align-items: center

  .search-form-input
    height: 100%
    font-size: 15px

  .search-form-submit
    left: 16px
    right: auto
    color: color-default

  #banner
    top: 66px
    background-position: center bottom

  #banner:after
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.04) 0%, rgba(0, 0, 0, 0.54) 100%)

  #header-title
    top: 66px
    left: 22px
    right: 22px

  #logo
    font-size: 42px
    line-height: 1.12

  #logo-wrap:after
    display: none

  #subtitle
    font-size: 17px
    line-height: 1.35

  #subtitle-wrap
    margin-top: 16px

  .site-hero-cta
    margin-top: 28px
    padding: 13px 18px 13px 22px
    font-size: 16px

  .site-hero-cta-icon
    width: 17px
    height: 17px
    font-size: 16px
