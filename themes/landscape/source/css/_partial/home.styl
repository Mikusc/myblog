.outer-home
  max-width: 1220px
  padding: 0 28px

#main.home-main
  float: none
  width: 100%
  margin: 0
  display: block

.home-page
  padding: 68px 0 96px

.home-section
  margin: 0 0 78px

.home-section-head
  display: flex
  align-items: flex-end
  justify-content: space-between
  gap: 30px
  padding-bottom: 24px
  margin-bottom: 34px
  border-bottom: 1px solid color-border

.home-section-kicker
  margin: 0 0 12px
  color: color-grey
  font: 700 13px font-sans
  letter-spacing: 1.2px
  text-transform: uppercase

.home-section-title
  margin: 0
  color: color-default
  font: 700 38px/1.12 font-sans

.home-section-note
  max-width: 520px
  margin: 14px 0 0
  color: color-grey
  font-size: 16px
  line-height: 1.7

.home-arrow-link
  display: inline-flex
  align-items: center
  gap: 12px
  color: color-default
  text-decoration: none
  font: 700 15px font-sans
  white-space: nowrap
  transition: opacity var(--motion-base) var(--motion-ease)
  &:hover
    opacity: 0.78
    text-decoration: underline
    .home-arrow-button svg
      transform: translate(2px, -2px)

.home-arrow-button
  width: 36px
  height: 36px
  border-radius: 50%
  color: #fff
  background: color-default
  flex: 0 0 36px

.home-overview-panel
  background: #fff
  display: grid
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 1.45fr)
  min-height: 330px

.home-overview-copy
  padding: 46px
  border-right: 1px solid color-border

.home-overview-title
  margin: 0
  color: color-default
  font: 700 42px/1.12 font-sans

.home-overview-text
  margin: 24px 0 0
  color: color-grey
  font-size: 17px
  line-height: 1.75

.home-stat-grid
  display: grid
  grid-template-columns: repeat(3, minmax(0, 1fr))
  border-left: 0

.home-stat
  padding: 44px 34px
  border-right: 1px solid color-border
  &:last-child
    border-right: 0

.home-stat-number
  display: block
  color: color-default
  font: 700 42px/1 font-sans

.home-stat-label
  display: block
  margin-top: 18px
  color: color-default
  font: 700 20px/1.3 font-sans

.home-stat-desc
  margin: 14px 0 0
  color: color-grey
  font-size: 15px
  line-height: 1.65

.home-news-events
  display: grid
  grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.9fr)
  gap: 52px

.home-column-head
  display: flex
  align-items: center
  justify-content: space-between
  gap: 20px
  margin-bottom: 24px

.home-column-title
  margin: 0
  color: color-default
  font: 700 26px/1.25 font-sans

.home-column-link
  display: inline-flex
  align-items: center
  gap: 7px
  color: color-default
  text-decoration: none
  font: 700 14px font-sans
  &:hover
    text-decoration: underline

.home-inline-arrow
  width: 15px
  height: 15px
  color: color-default
  flex: 0 0 15px
  svg
    width: 15px
    height: 15px

.home-news-grid
  display: grid
  grid-template-columns: repeat(3, minmax(0, 1fr))
  gap: 28px

.home-news-card
  display: block
  color: color-default
  text-decoration: none
  background: #fff
  min-height: 100%
  transition: background var(--motion-base) var(--motion-ease)
  &:hover
    background: var(--nottingham-blue-5)
    .home-news-title
      text-decoration: underline
    .home-news-arrow svg
      transform: translate(2px, -2px)

.home-news-media
  min-height: 168px
  padding: 24px
  background: color-default
  color: #fff
  display: flex
  align-items: flex-end
  justify-content: space-between
  gap: 18px

.home-news-date
  color: rgba(255, 255, 255, 0.76)
  font: 700 13px/1.2 font-sans
  letter-spacing: 0.8px
  text-transform: uppercase

.home-news-arrow
  width: 40px
  height: 40px
  border-radius: 50%
  background: #fff
  color: color-default
  flex: 0 0 40px

.home-news-body
  padding: 22px 22px 26px

.home-news-title
  margin: 0
  color: color-default
  font: 700 19px/1.35 font-sans

.home-news-excerpt
  margin: 14px 0 0
  color: color-grey
  font-size: 14px
  line-height: 1.7

.home-event-list
  display: grid
  gap: 24px

.home-event-card
  display: grid
  grid-template-columns: 150px minmax(0, 1fr)
  min-height: 150px
  color: color-default
  text-decoration: none
  background: #fff
  transition: background var(--motion-base) var(--motion-ease)
  &:hover
    background: var(--nottingham-blue-5)
    .home-event-title
      text-decoration: underline

.home-event-datebox
  padding: 28px 24px
  border-right: 1px solid color-border
  display: flex
  flex-direction: column
  justify-content: space-between

.home-event-day
  color: color-default
  font: 700 27px/1.15 font-sans

.home-event-year
  color: color-grey
  font: 700 13px/1 font-sans

.home-event-body
  padding: 28px 28px 26px

.home-event-type
  display: block
  margin-bottom: 12px
  color: color-grey
  font: 700 12px/1 font-sans
  letter-spacing: 1px
  text-transform: uppercase

.home-event-title
  margin: 0
  color: color-default
  font: 700 19px/1.4 font-sans

.home-pathway-grid
  display: grid
  grid-template-columns: repeat(3, minmax(0, 1fr))
  gap: 28px

.home-pathway-card
  display: flex
  min-height: 230px
  flex-direction: column
  justify-content: space-between
  background: #fff
  color: color-default
  padding: 32px
  text-decoration: none
  border-top: 6px solid color-default
  transition: background var(--motion-base) var(--motion-ease), border-color var(--motion-base) var(--motion-ease)
  &:hover
    background: var(--nottingham-blue-5)
    .home-pathway-title
      text-decoration: underline
    .home-arrow-button svg
      transform: translate(2px, -2px)

.home-pathway-title
  margin: 0
  color: color-default
  font: 700 25px/1.25 font-sans

.home-pathway-desc
  margin: 18px 0 28px
  color: color-grey
  font-size: 15px
  line-height: 1.7

.home-pathway-footer
  display: flex
  align-items: center
  justify-content: space-between
  gap: 18px
  color: color-default
  font-weight: 700

@media mq-mobile-tablet
  .outer-home
    padding: 0 20px

  .home-page
    padding: 42px 0 70px

  .home-section
    margin-bottom: 58px

  .home-section-head
    display: block
    padding-bottom: 20px
    margin-bottom: 26px

  .home-section-title,
  .home-overview-title
    font-size: 32px
    line-height: 1.18

  .home-section-note
    font-size: 15px

  .home-arrow-link
    margin-top: 22px

  .home-overview-panel,
  .home-news-events,
  .home-pathway-grid
    grid-template-columns: 1fr

  .home-overview-copy
    padding: 30px 24px
    border-right: 0
    border-bottom: 1px solid color-border

  .home-stat-grid
    grid-template-columns: 1fr

  .home-stat
    padding: 28px 24px
    border-right: 0
    border-bottom: 1px solid color-border
    &:last-child
      border-bottom: 0

  .home-news-events
    gap: 44px

  .home-news-grid
    grid-template-columns: 1fr
    gap: 24px

  .home-news-media
    min-height: 136px

  .home-event-card
    grid-template-columns: 118px minmax(0, 1fr)
    min-height: 132px

  .home-event-datebox
    padding: 22px 18px

  .home-event-day
    font-size: 22px

  .home-event-body
    padding: 22px 20px

  .home-pathway-card
    min-height: 190px
    padding: 28px 24px
