#footer
  background: color-footer-background
  color: #fff
  padding: 80px 42px 60px
  position: relative
  width: 100%
  z-index: 1
  a
    color: inherit
    text-decoration: none

.footer-shell
  max-width: 1440px
  margin: 0 auto

.footer-flex-wrapper
  display: grid
  grid-template-columns: minmax(180px, 1fr) minmax(320px, 1.6fr) minmax(160px, 0.8fr) minmax(260px, 1.1fr)
  gap: 44px
  justify-content: space-between

.footer-sub-title
  font-size: 18px
  font-weight: 700
  line-height: 1.4

.footer-sub-list
  margin-top: 24px

.footer-sub-item
  color: rgba(255, 255, 255, 0.68)
  font-size: 14px
  line-height: 1.65
  margin-bottom: 18px

.hover-link
  transition: color 0.25s ease, opacity 0.25s ease
  &:hover
    color: #fff

.footer-map-nav
  display: inline-flex
  align-items: center
  gap: 6px
  margin-top: 32px
  &:hover
    .footer-arrow
      transform: translate(2px, -2px)

.footer-arrow
  display: inline-flex
  align-items: center
  justify-content: center
  width: 26px
  height: 26px
  transition: transform var(--motion-base) var(--motion-ease)
  svg
    width: 18px
    height: 18px

.footer-link-list
  display: grid
  grid-template-columns: repeat(2, minmax(0, 1fr))
  gap: 28px

.footer-media-wrapper
  display: flex
  flex-wrap: wrap
  gap: 22px
  margin-top: 24px

.media-icon
  display: inline-flex
  align-items: center
  justify-content: center
  width: 28px
  height: 28px
  color: rgba(255, 255, 255, 0.68)
  font-size: 22px
  line-height: 1
  opacity: 0.68
  transition: color 0.25s ease, opacity 0.25s ease
  &:hover
    color: #fff
    opacity: 1
  img
    display: block
    width: 100%
    height: 100%
    object-fit: contain

.media-icon-text
  display: inline-flex
  align-items: center
  justify-content: center
  width: 22px
  height: 22px
  border: 1px solid currentColor
  border-radius: 50%
  font: 700 12px font-sans
  line-height: 1

.footer-column-4
  display: flex
  flex-direction: column
  gap: 10px

.footer-link-wrapper
  display: flex
  align-items: center
  justify-content: space-between
  gap: 22px
  width: 100%
  padding: 18px 16px 18px 20px
  background: #fff
  color: #000
  border-radius: 4px
  transition: opacity var(--motion-base) var(--motion-ease), background var(--motion-base) var(--motion-ease)
  &:hover
    opacity: 0.78
    .link-arrow svg
      transform: translate(2px, -2px)

#footer .footer-link-wrapper
  color: #000

.link-text
  font-size: 17px
  font-weight: 700
  line-height: 1.35

.link-btn-wrapper
  display: inline-flex
  align-items: center
  justify-content: center
  flex: 0 0 38px
  width: 38px
  height: 38px
  border-radius: 50%
  background: color-default
  color: #fff

.link-arrow
  display: inline-flex
  width: 19px
  height: 19px
  svg
    width: 19px
    height: 19px

.footer-split-line
  width: 100%
  height: 1px
  margin: 44px 0 48px
  background: rgba(255, 255, 255, 0.2)

.footer-copyright-wrapper
  display: flex
  align-items: center
  justify-content: space-between
  gap: 28px
  color: rgba(255, 255, 255, 0.62)
  font-size: 14px
  line-height: 1.5

.copyright-links
  display: flex
  align-items: center
  justify-content: flex-end
  flex-wrap: wrap
  gap: 22px

.copyright-text
  color: rgba(255, 255, 255, 0.62)
  transition: color 0.25s ease
  a
    color: inherit
  &.hover-link:hover,
  a:hover
    color: #fff

@media mq-mobile-tablet
  #footer
    padding: 44px 22px 40px

  .footer-flex-wrapper
    display: flex
    flex-direction: column
    gap: 30px

  .footer-sub-title
    font-size: 16px

  .footer-sub-list
    margin-top: 16px

  .footer-sub-item
    margin-bottom: 14px

  .footer-column-4
    order: 2

  .footer-column-2
    order: 3

  .footer-column-3
    order: 4

  .footer-link-wrapper
    padding: 14px 16px

  .link-text
    font-size: 14px

  .link-btn-wrapper
    flex-basis: 32px
    width: 32px
    height: 32px

  .footer-link-list
    grid-template-columns: 1fr
    gap: 0

  .footer-media-wrapper
    gap: 24px
    justify-content: flex-start

  .footer-split-line
    margin: 30px 0

  .footer-copyright-wrapper
    align-items: flex-start
    flex-direction: column
    gap: 12px
    font-size: 12px

  .copyright-links
    justify-content: flex-start
    gap: 16px
