@import "nib"
@import "_variables"
@import "_util/mixin"
@import "_util/grid"

global-reset()

html, body
  max-width: 100%
  overflow-x: hidden

*, *::before, *::after
  box-sizing: border-box

input, button
  margin: 0
  padding: 0
  &::-moz-focus-inner
    border: 0
    padding: 0

:root
  --nottingham-blue: #10263b
  --nottingham-blue-80: #405162
  --nottingham-blue-20: #cfd4d8
  --nottingham-blue-5: #f3f4f5
  --portland-stone: #faf6ef
  --portland-stone-40: #fdfbf9
  --forest-green: #005f36
  --trent-turquoise: #37b4b0
  --bg-1: #eef1f4
  --bg-2: #eef1f4
  --ink: #10263b
  --muted: #405162
  --card: #ffffff
  --accent: #10263b
  --accent-2: #37b4b0
  --accent-3: #faf6ef
  --ring: rgba(16, 38, 59, 0.16)
  --shadow: 0 14px 30px rgba(16, 38, 59, 0.08)

html, body, #container
  height: 100%

body
  background: var(--bg-1)
  font: font-size font-sans
  -webkit-text-size-adjust: 100%
  color: color-default
  line-height: line-height
  position: relative
  overflow-x: hidden

h1, h2, h3, h4, h5, h6,
#logo, #subtitle
  font-family: font-sans
  letter-spacing: 0

.site-drawn-arrow
  display: inline-flex
  align-items: center
  justify-content: center
  svg
    width: 18px
    height: 18px
    display: block
  path
    fill: none
    stroke: currentColor
    stroke-width: 3
    stroke-linecap: square
    stroke-linejoin: miter

.outer
  clearfix()
  max-width: (column-width + gutter-width) * columns + gutter-width
  margin: 0 auto
  padding: 0 gutter-width
  position: relative
  z-index: 1

.inner
  column(columns)

.left, .alignleft
  float: left

.right, .alignright
  float: right

.clear
  clear: both

#container
  position: relative
  z-index: 1

.mobile-nav-on
  overflow: hidden

#wrap
  height: 100%
  width: 100%
  position: absolute
  top: 0
  left: 0
  transition: 0.2s ease-out
  z-index: 1
  background: transparent
  .mobile-nav-on &
    left: mobile-nav-width

if sidebar and sidebar isnt bottom
  #main
    @media mq-normal
      column(main-column)

if sidebar is left
  @media mq-normal
    #main
      float: right

@import "_extend"
@import "_partial/header"
@import "_partial/article"
@import "_partial/comment"
@import "_partial/archive"
@import "_partial/footer"
@import "_partial/highlight"
@import "_partial/mobile"

if sidebar
  @import "_partial/sidebar"

@import "_partial/home"

/* Math (KaTeX) */
.katex
  font-size: 1.15em

.katex-display
  overflow-x: auto
  overflow-y: hidden
